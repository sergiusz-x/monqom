meta {
  name: Create Budget
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/budgets
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "amount": 800,
    "category_id": "{{categoryId}}",
    "year": 2026,
    "month": 3
  }
}
