meta {
  name: Create Transaction
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/transactions
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "amount": 10.5,
    "date": "2026-03-23",
    "category_id": "{{categoryId}}",
    "notes": "Lunch with the team",
    "tags": ["Food", "Work"],
    "payment_source_id": "{{paymentSourceId}}"
  }
}
