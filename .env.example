# Local development only — never copy production secrets into this file.
PORT=3000
NODE_ENV=development
POSTGRES_USER=monqom
POSTGRES_PASSWORD=replace-with-a-secure-password
POSTGRES_DB=monqom_dev
DATABASE_URL=postgresql://monqom:replace-with-a-secure-password@localhost:5432/monqom_dev
SESSION_SECRET=replace-with-at-least-32-random-characters
TOTP_ENCRYPTION_KEY=replace-with-a-separate-32-character-key
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=info
TURNSTILE_ENABLED=false
# Production-only:
# RESEND_API_KEY=re_...
# EMAIL_FROM=Monqom <noreply@example.com>
# TURNSTILE_SECRET_KEY=...
# VITE_TURNSTILE_SITE_KEY=...
# APP_VERSION=v1.0.0
# GIT_SHA=abc123
