PORT=3000
NODE_ENV=development

# PostgreSQL credentials (used by docker-compose.dev.yml)
POSTGRES_USER=monqom
POSTGRES_PASSWORD=replace-with-a-secure-password
POSTGRES_DB=monqom_dev

DATABASE_URL=postgresql://monqom:replace-with-a-secure-password@localhost:5432/monqom_dev
SESSION_SECRET=replace-with-a-long-random-string
TOTP_ENCRYPTION_KEY=replace-with-a-separate-long-random-string
CORS_ALLOWED_ORIGINS=http://localhost:3000
